APP_NAME=ProjectTrace API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
ENVIRONMENT=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# PostgreSQL (primary)
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=projecttrace
DB_USER=postgres
DB_PASSWORD=
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=projecttrace
PG_USER=postgres
PG_PASSWORD=
PG_SSLMODE=disable

# Optional fallback for local quick test:
SQLITE_PATH=./data/projecttrace.db
FILE_STORE_PATH=./data/document_store.json
UPLOAD_DIR_PATH=./data/uploads

# Redis (optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB (optional)
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=projecttrace
MONGO_HOST=127.0.0.1
MONGO_PORT=27017

# MinIO (optional)
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=projecttrace
MINIO_SECURE=false
MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SCHEME=http
