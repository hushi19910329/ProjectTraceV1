# Optional fallback for local quick test:
SQLITE_PATH=./data/projecttrace.db
FILE_STORE_PATH=./data/document_store.json
UPLOAD_DIR_PATH=./data/uploads

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
