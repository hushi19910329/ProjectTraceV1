APP_NAME=ProjectTrace API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
ENVIRONMENT=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=projecttrace
DB_USER=postgres
